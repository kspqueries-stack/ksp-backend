# =============================================================================
# KSP Workboard - Local Environment Variables
# =============================================================================
# Copy this file to .env and fill in YOUR values.
# This is for LOCAL development only. Production uses systemd env vars.
# =============================================================================

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/ksp_workboard
DB_USERNAME=postgres
DB_PASSWORD=your_database_password

# --- JWT ---
JWT_SECRET=your-local-jwt-secret-at-least-32-characters-long

# --- AI Provider (groq for local dev) ---
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_from_console.groq.com

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=local
